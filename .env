# Transcriber Configuration
# Github: https://github.com/Br3n0k/transcriber
# Brendown Ferreira: https://github.com/Br3n0k

DEBUG=true

# Custom Directories (optional - if not defined, defaults are used)
# STORAGE_UPLOADS=./storage/uploads
# STORAGE_TRANSCRIPTIONS=./storage/transcriptions
# TEMPLATES_DIR=./app/templates
# STATIC_DIR=./app/static

# FFmpeg Configuration
FFMPEG_AUTO_SETUP=true  # If true, attempts to auto-install FFmpeg via imageio-ffmpeg on startup

# Whisper Configuration
# WHISPER_MODEL=base  # Options: tiny, base, small, medium, large-v2, large-v3
# WHISPER_DEVICE=auto # Options: auto, cuda, cpu
