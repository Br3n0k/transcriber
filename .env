# Configurações do Transcriber
# Renomeie este arquivo para .env se quiser customizar

# DEBUG=true

# Diretórios customizados (opcional - se não definir, usa os padrões)
# STORAGE_UPLOADS=./storage/uploads
# STORAGE_TRANSCRIPTIONS=./storage/transcriptions
# TEMPLATES_DIR=./app/templates
# STATIC_DIR=./app/static

# Configuração do FFmpeg
FFMPEG_AUTO_SETUP=true  # Se true, tenta instalar o FFmpeg automaticamente via imageio-ffmpeg na inicialização
